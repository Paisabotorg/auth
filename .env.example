# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://paisabot_auth:YOUR_PASSWORD@127.0.0.1:5433/paisabot_auth

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_byte_hex_secret_here

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=643657176504-gnm7r3do4oe3lbs116u936mhjkuqtg1a.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://auth.paisabot.com/auth/callback

# ── Service config ────────────────────────────────────────
PORT=3100
NODE_ENV=production
BASE_URL=https://auth.paisabot.com
DEFAULT_REDIRECT=https://paisabot.com
COOKIE_DOMAIN=.paisabot.com
