NODE_ENV=production
PORT=3100

# Postgres — paisabot_cms database on the VPS (creates paisabot_auth schema within it)
DATABASE_URL=postgresql://paisabot_cms:PASSWORD@localhost:5432/paisabot_cms

# Redis (VPS local instance)
REDIS_URL=redis://localhost:6379

# RSA keypair for RS256 JWT — generate with: npm run keygen
PB_AUTH_PRIVATE_KEY_PATH=/etc/paisabot/auth/private.pem
PB_AUTH_PUBLIC_KEY_PATH=/etc/paisabot/auth/public.pem
PB_AUTH_KID=pb-auth-v1

# Google OAuth 2.0 — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: https://auth.paisabot.com/callback/google
GOOGLE_CLIENT_ID=643657176504-gnm7r3do4oe3lbs116u936mhjkuqtg1a.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://auth.paisabot.com/callback/google

COOKIE_DOMAIN=.paisabot.com
DEFAULT_REDIRECT=https://paisabot.com
