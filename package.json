{
  "name": "paisabot-auth",
  "version": "2.0.0",
  "description": "Paisabot auth service — Google OAuth, self-hosted JWT, Postgres sessions",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start":   "node src/index.js",
    "dev":     "node --watch src/index.js",
    "keygen":  "node scripts/generate-keys.js",
    "migrate": "psql \"$DATABASE_URL\" -f migrations/001_auth_schema.sql"
  },
  "dependencies": {
    "cookie-parser":      "^1.4.7",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet":             "^8.0.0",
    "jsonwebtoken":       "^9.0.2",
    "pg":                 "^8.13.0",
    "redis":              "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
